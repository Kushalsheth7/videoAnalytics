# =========================================================================
# Creatorjoy RAG Chatbot - Environment Configuration Example
# Copy this file to `.env` and fill in your keys.
# Get your free Groq API key at: https://console.groq.com/keys
# =========================================================================

# Groq API key — used for both the Llama LLM and Whisper transcription (100% free)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key — used for text embeddings via network to save RAM (100% free tier)
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Vector DB Storage Configuration
# Persistent directory for local ChromaDB instance (costs $0)
CHROMA_PERSIST_DIRECTORY=data/chroma

# LLM Model Selection (Groq)
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, llama3-8b-8192
LLM_MODEL=llama-3.3-70b-versatile

# Embedding Model (runs 100% locally via HuggingFace, downloaded on first run ~90MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Backend Server
PORT=8000
HOST=127.0.0.1
